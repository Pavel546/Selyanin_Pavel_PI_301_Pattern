from abc import ABC, abstractmethod

# Интерфейс парсера
class Parser(ABC):
    @abstractmethod
    def parse(self, raw: str) -> list[dict]:
        pass

class JsonParser(Parser):
    def parse(self, raw: str) -> list[dict]:
        import json
        return json.loads(raw)

class CsvParser(Parser):
    def parse(self, raw: str) -> list[dict]:
        import csv, io
        return list(csv.DictReader(io.StringIO(raw)))

class XmlParser(Parser):
    def parse(self, raw: str) -> list[dict]:
        import xml.etree.ElementTree as ET
        root = ET.fromstring(raw)
        return [{child.tag: child.text for child in item} for item in root]

# Абстрактный импортёр
class DataImporter(ABC):
    @abstractmethod
    def create_parser(self):
        pass

    def parse(self, raw: str) -> list[dict]:
        parser = self.create_parser()  # создаём парсер
        return parser.parse(raw)       # парсим данные

# Конкретные импортёры
class JsonImporter(DataImporter):
    def create_parser(self):
        return JsonParser()

class CsvImporter(DataImporter):
    def create_parser(self):
        return CsvParser()

class XmlImporter(DataImporter):
    def create_parser(self):
        return XmlParser()

# Использование
raw_json = '[{"name": "Иван", "age": 25}]'
print(JsonImporter().parse(raw_json))
